{
  "name": "@false00/pi-powerline",
  "version": "0.8.4",
  "description": "Maintained fork of pi-powerline with stale-session-safe UI rendering for pi coding agent",
  "homepage": "https://github.com/false00/pi-powerline#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/false00/pi-powerline.git"
  },
  "bugs": {
    "url": "https://github.com/false00/pi-powerline/issues"
  },
  "type": "module",
  "files": [
    "extensions/",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "package.json",
    "CHANGELOG.md",
    "LICENSE",
    "assets/"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "powerline",
    "extension"
  ],
  "author": "false00",
  "contributors": [
    "jwu (upstream author)"
  ],
  "license": "MIT",
  "scripts": {
    "test": "node --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.check.json --noEmit --ignoreDeprecations 6.0",
    "lint": "npm run format:check && npm run typecheck && npm test",
    "format": "prettier --write \"**/*.{ts,md,json,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,md,json,cjs}\"",
    "prepare": "[ -d .git ] && simple-git-hooks || true",
    "prepublishOnly": "npm run lint && npm pack --dry-run",
    "release": "GH_TOKEN=$(gh auth token) semantic-release --no-ci",
    "release:dry": "GH_TOKEN=$(gh auth token) semantic-release --no-ci --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "repositoryUrl": "https://github.com/false00/pi-powerline.git",
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npm run format:check && npm run typecheck && npm test",
    "commit-msg": "npx commitlint --edit \"$1\""
  },
  "engines": {
    "node": ">=20"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "image": "https://raw.githubusercontent.com/false00/pi-powerline/refs/heads/main/assets/pi-powerline.png"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@types/node": "^24.10.1",
    "@commitlint/config-conventional": "^20.5.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  }
}
